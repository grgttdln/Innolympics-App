# Copy to .env.local and fill in your Neon connection string
# Get this from: https://console.neon.tech → your project → Connection Details
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Google AI Studio API key (Gemini)
# Used for voice-journal transcription, Gemini Live conversation,
# grounding validation, and journaling follow-up suggestions.
# Get one from https://aistudio.google.com/apikey
GEMINI_API_KEY=""
